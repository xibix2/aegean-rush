generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Club {
  id                     String             @id @default(cuid())
  slug                   String             @unique
  name                   String
  currency               String
  primaryHex             String?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  subscriptionPlan       SubscriptionPlan   @default(ENTERPRISE)
  subscriptionStatus     SubscriptionStatus @default(INACTIVE)
  stripeCustomerId       String?            @unique
  stripeSubscriptionId   String?            @unique
  stripePriceId          String?
  trialEndsAt            DateTime?
  stripeConnectAccountId String?            @unique
  emailFromEmail         String?
  emailFromName          String?
  logoKey                String?
  location               String?
  activities             Activity[]
  setting                AppSetting?        @relation("ClubSetting")
  customers              Customer[]         @relation("ClubCustomers")
  homepageSections       HomepageSection[]
  staffInvites           StaffInvite[]
  users                  User[]
}

model HomepageSection {
  id                String                 @id @default(cuid())
  clubId            String
  type              HomepageSectionType
  enabled           Boolean                @default(true)
  sortOrder         Int                    @default(0)
  title             String?
  subtitle          String?
  body              String?
  primaryCtaLabel   String?
  primaryCtaHref    String?
  secondaryCtaLabel String?
  secondaryCtaHref  String?
  badgeText         String?
  dataJson          Json?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  faqItems          HomepageFaqItem[]
  featureItems      HomepageFeatureItem[]
  galleryImages     HomepageGalleryImage[]
  club              Club                   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([clubId, type], name: "clubId_type")
  @@index([clubId, sortOrder])
}

model HomepageGalleryImage {
  id        String          @id @default(cuid())
  sectionId String
  imageUrl  String
  altText   String?
  caption   String?
  sortOrder Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  section   HomepageSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId, sortOrder])
}

model HomepageFaqItem {
  id        String          @id @default(cuid())
  sectionId String
  question  String
  answer    String
  sortOrder Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  section   HomepageSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId, sortOrder])
}

model HomepageFeatureItem {
  id          String          @id @default(cuid())
  sectionId   String
  title       String
  description String?
  icon        String?
  sortOrder   Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  section     HomepageSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId, sortOrder])
}

model User {
  id          String               @id @default(cuid())
  email       String
  password    String
  role        UserRole             @default(ADMIN)
  clubId      String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  resetTokens PasswordResetToken[]
  club        Club?                @relation(fields: [clubId], references: [id])

  @@unique([email, clubId])
  @@index([clubId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Customer {
  id        String    @id @default(cuid())
  name      String
  email     String
  phone     String?
  createdAt DateTime  @default(now())
  clubId    String
  bookings  Booking[]
  club      Club      @relation("ClubCustomers", fields: [clubId], references: [id])

  @@unique([clubId, email])
  @@index([clubId])
}

model Activity {
  id                 String                   @id @default(cuid())
  name               String
  slug               String
  description        String?
  durationMin        Int
  minParty           Int
  maxParty           Int
  basePrice          Int?
  requiresInstructor Boolean
  coverImageUrl      String?
  locationId         String
  active             Boolean                  @default(true)
  createdAt          DateTime                 @default(now())
  sport              String                   @default("tennis")
  updatedAt          DateTime                 @updatedAt
  clubId             String
  ageInfo            String?
  bringText          String?
  cancellationText   String?
  guestsPerUnit      Int?
  includedText       String?
  maxUnitsPerBooking Int?
  meetingPoint       String?
  mode               ActivityMode             @default(FIXED_SEAT_EVENT)
  pricingNotes       String?
  safetyInfo         String?
  skillLevel         String?
  slotIntervalMin    Int?
  club               Club                     @relation(fields: [clubId], references: [id])
  durationOptions    ActivityDurationOption[]
  bookings           Booking[]
  timeSlots          TimeSlot[]

  @@unique([clubId, slug])
  @@index([clubId])
}

model ActivityDurationOption {
  id          String   @id @default(cuid())
  activityId  String
  label       String?
  durationMin Int
  priceCents  Int
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  activity    Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([activityId, sortOrder])
}

model TimeSlot {
  id         String     @id @default(cuid())
  activityId String
  startAt    DateTime
  capacity   Int
  endAt      DateTime?
  priceCents Int
  status     SlotStatus @default(open)
  bookings   Booking[]
  activity   Activity   @relation(fields: [activityId], references: [id])

  @@unique([activityId, startAt])
  @@index([activityId, startAt])
}

model Booking {
  id                   String        @id @default(cuid())
  customerId           String
  activityId           String
  timeSlotId           String
  partySize            Int
  totalPrice           Int
  status               BookingStatus @default(pending)
  notes                String?
  createdAt            DateTime      @default(now())
  bookingEndAt         DateTime?
  bookingStartAt       DateTime?
  durationMinSnapshot  Int?
  pricingLabelSnapshot String?
  reservedUnits        Int           @default(1)
  unitPriceSnapshot    Int?
  contactEmail         String?
  contactName          String?
  contactPhone         String?
  cancelledAt          DateTime?
  publicToken          String        @unique @default(cuid())
  activity             Activity      @relation(fields: [activityId], references: [id])
  customer             Customer      @relation(fields: [customerId], references: [id])
  timeSlot             TimeSlot      @relation(fields: [timeSlotId], references: [id])
  payment              Payment?

  @@index([timeSlotId])
  @@index([activityId, bookingStartAt, bookingEndAt])
}

model Payment {
  id               String          @id @default(cuid())
  bookingId        String          @unique
  provider         PaymentProvider
  providerIntentId String          @unique
  amount           Int
  currency         String          @default("EUR")
  status           PaymentStatus
  createdAt        DateTime        @default(now())
  booking          Booking         @relation(fields: [bookingId], references: [id])
}

model AppSetting {
  id        String   @id @default(cuid())
  tz        String
  lang      String?
  currency  String?
  theme     String?
  accent    String?
  updatedAt DateTime @updatedAt
  clubId    String   @unique
  club      Club     @relation("ClubSetting", fields: [clubId], references: [id])
}

model StaffInvite {
  id        String    @id @default(cuid())
  clubId    String
  email     String
  role      UserRole  @default(STAFF)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  club      Club      @relation(fields: [clubId], references: [id])

  @@unique([clubId, email, usedAt])
  @@index([clubId])
}

enum SubscriptionPlan {
  BASIC
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  INACTIVE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum ActivityMode {
  FIXED_SEAT_EVENT
  DYNAMIC_RENTAL
  HYBRID_UNIT_BOOKING
}

enum HomepageSectionType {
  HERO
  GALLERY
  ACTIVITIES
  HOW_IT_WORKS
  WHY_CHOOSE_US
  LOCATION
  FAQ
  FINAL_CTA
}

enum UserRole {
  SUPERADMIN
  ADMIN
  MANAGER
  COACH
  STAFF
}

enum SlotStatus {
  open
  closed
}

enum BookingStatus {
  pending
  paid
  cancelled
  refunded
}

enum PaymentProvider {
  stripe
}

enum PaymentStatus {
  requires_action
  succeeded
  refunded
  failed
}
